# Copy this to terraform.tfvars and fill in values
# terraform.tfvars is git-ignored

aws_region    = "us-east-1"
project_name  = "gitlab"
vpc_cidr      = "10.0.0.0/16"
instance_type = "t3.xlarge"

# Your GitLab domain
domain_name = "code.agiledefense.xyz"

# DNS is managed via Route53 subdomain delegation.
# The agiledefense.xyz zone is in a separate AWS account.
# After terraform apply, add the NS records from `terraform output route53_nameservers`
# to the parent zone for subdomain delegation.

# Backup
data_volume_size          = 100
backup_replication_region = "us-west-2"

# DoD IL2 classification tag
data_classification = "IL2"

# FIPS-validated AMI for IL2 compliance (SC-13) -- set true for production
# use_fips_ami = true

# Cross-region backup replication (CP-6) -- set true for production
# enable_backup_replication = false

# Email for CloudWatch alarm notifications (must confirm subscription)
alert_email = "admin@agiledefense.xyz"
