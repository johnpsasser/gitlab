# Copy this to terraform.tfvars and fill in values
# terraform.tfvars is git-ignored

aws_region    = "us-east-1"
project_name  = "gitlab"
vpc_cidr      = "10.0.0.0/16"
instance_type = "t3.xlarge"

# Your GitLab domain
domain_name = "gitlab.yourcompany.com"

# DNS is managed via Cloudflare (outside Terraform).
# After terraform apply, create a CNAME record in Cloudflare pointing
# your domain to the ALB DNS name (shown in terraform output alb_dns_name).
# Set Cloudflare proxy status to "DNS only" (gray cloud).

# Backup
data_volume_size          = 100
backup_replication_region = "us-west-2"

# DoD IL2 classification tag
data_classification = "IL2"

# Email for CloudWatch alarm notifications (must confirm subscription)
# alert_email = "admin@yourcompany.com"
